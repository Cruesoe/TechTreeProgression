<?xml version="1.0" encoding="utf-8" ?>
<Patch>
<!-- Rename Vanilla Factions Expanded - Tribals reseach tab -->
    <Operation Class="PatchOperationFindMod">
        <mods>
            <li>Vanilla Factions Expanded - Tribals</li>
        </mods>
        
        <match Class="PatchOperationReplace">
            <xpath>Defs/ResearchTabDef[defName="Basic" or defName="VFET_Basic"]/label</xpath>
            <value>
                <label>Animal</label>
            </value>
        </match>
    </Operation>
</Patch>